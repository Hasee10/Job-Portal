# CockroachDB connection string (Cloud console -> Connect). This is the
# live database as of the CockroachDB cutover - same credential used for
# both reads and writes, since CockroachDB has no RLS/anon-key equivalent
# to split those apart the way Supabase did. bordful-main reads from the
# same cluster (via its own COCKROACH_DATABASE_URL in .env.local).
COCKROACH_DATABASE_URL=postgresql://user:password@host:26257/jobs_db?sslmode=verify-full

# Supabase - FROZEN, no longer used. Left here only for reference / easy
# rollback if you ever need to point the scraper back at it.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Adzuna (https://developer.adzuna.com/) - free tier API keys. No Gulf/Middle
# East coverage (checked 2026-07) - used for North America + Asia instead.
# Comma-separated country codes and keywords, each combo queried and merged.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRIES=us,ca,in,sg
ADZUNA_KEYWORDS=procurement,supply chain,information technology,artificial intelligence,data analyst

# Jooble (https://jooble.org/api/about) - free API key. Covers the Gulf
# (UAE/Saudi/Qatar/Kuwait/Bahrain) alongside South Asia and North America -
# comma-separated keywords and locations, each combo queried and merged.
JOOBLE_API_KEY=
JOOBLE_KEYWORDS=procurement,supply chain,information technology,artificial intelligence,data analyst
JOOBLE_LOCATIONS=United Arab Emirates,Saudi Arabia,Qatar,Kuwait,Bahrain,Pakistan,India,United States

# GulfTalent (https://www.gulftalent.com) - no signup needed, no free API key
# required. Uses the plain JSON endpoint behind the site's own search box.
# One query already spans every country GulfTalent covers (UAE, Saudi,
# Qatar, Kuwait, Oman, Bahrain and more), so this only needs keywords.
GULFTALENT_KEYWORDS=procurement,supply chain,information technology,artificial intelligence,data analyst

# NaukriGulf (https://www.naukrigulf.com) - same rationale as GulfTalent
# above, no signup/key needed. One query spans every Gulf country it covers.
NAUKRIGULF_KEYWORDS=procurement,supply chain,information technology,artificial intelligence,data analyst

# Bayt (https://www.bayt.com) - no signup/key needed, plain server-rendered
# HTML. Unlike GulfTalent/NaukriGulf, one query is scoped to a single
# country, so this runs a country x keyword matrix. Defaults to every GCC
# country plus the Levant (2026-07 scope: GCC first, Middle East incl.
# Levant overall). BAYT_MAX_PAGES caps pages fetched per combo (30 jobs/page).
BAYT_COUNTRIES=uae,saudi-arabia,qatar,kuwait,bahrain,oman,jordan,lebanon,iraq,syria,palestine
BAYT_KEYWORDS=procurement,supply chain,information technology,artificial intelligence,data analyst
BAYT_MAX_PAGES=2

# Optional: comma-separated Greenhouse/Lever/Ashby board tokens to add to the
# defaults baked into sources/companies.json (e.g. "airbnb,figma:lever,notion:ashby")
ATS_EXTRA_BOARDS=

# Optional CloakBrowser Pro license key (https://cloakbrowser.dev). Leave blank
# to use the free Chromium build - fine for the browser-based sources here.
CLOAKBROWSER_LICENSE_KEY=

# Optional residential proxy for the browser-based sources (recommended for
# Indeed/Glassdoor/Naukri, which actively block datacenter IPs and cloud VMs).
# Format: http://user:pass@host:port
SCRAPER_PROXY=

LOG_LEVEL=INFO

# Days a job stays in the table after being marked discontinued before
# retention_cleanup.py deletes it permanently. See README "Bound database
# growth long-term".
RETENTION_DAYS=90
