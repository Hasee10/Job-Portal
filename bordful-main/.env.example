# Supabase (job data source). Server-only reads use the anon key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Airtable — deprecated, no longer used (replaced by Supabase above).
AIRTABLE_ACCESS_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Jobs

# Email Provider Configuration
# Choose your email provider: encharge, mailchimp, convertkit, sendgrid
EMAIL_PROVIDER=encharge

# Encharge Configuration
ENCHARGE_WRITE_KEY=your_encharge_write_key_here

# Application URL
NEXT_PUBLIC_APP_URL=https://yourdomain.com